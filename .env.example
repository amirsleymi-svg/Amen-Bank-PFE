# ═══════════════════════════════════════════════════════════════
#  AMEN BANK — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  ⚠️  NEVER commit the .env file to source control.
# ═══════════════════════════════════════════════════════════════

APP_NAME=Amen Bank
APP_ENV=development
APP_PORT=8080
API_URL=http://localhost:8080/api/v1
CHATBOT_URL=http://localhost:8000

# ─── Database ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=amenbank
DB_USER=amenbank_user
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_256_bit_secret_key_here_very_long
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── TOTP ────────────────────────────────────────────────────────
TOTP_ISSUER=AmenBank
TOTP_PERIOD=30
TOTP_DIGITS=6

# ─── Admin ───────────────────────────────────────────────────────
ADMIN_SECRET_KEY_HASH=change_me_bcrypt_hash_of_admin_secret

# ─── Email / SMTP ────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@amenbank.com
MAIL_PASSWORD=change_me_app_password
MAIL_FROM=noreply@amenbank.com
MAIL_FROM_NAME=Amen Bank

# ─── File Upload ─────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=application/pdf,image/jpeg,image/png
UPLOAD_PATH=/data/uploads

# ─── Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password

# ─── Security ────────────────────────────────────────────────────
BCRYPT_STRENGTH=12
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ─── Chatbot ─────────────────────────────────────────────────────
CHATBOT_RATE_LIMIT=20
CHATBOT_SESSION_TTL_SECONDS=1800
OPENAI_API_KEY=change_me_if_using_openai
